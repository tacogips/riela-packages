        "packages/example/src/index.ts",
        "packages/example/src/index.test.ts"
      ],
      "verification": [
        {
          "command": "bun test packages/example/src/index.test.ts",
          "result": "passed"
        }
      ],
      "reviewSummary": "Accepted explicit-target adversarial review with no high or medium findings."
    }
