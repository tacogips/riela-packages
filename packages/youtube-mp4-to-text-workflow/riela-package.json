{
  "name": "@tacogips/youtube-mp4-to-text-workflow",
  "version": "0.1.0",
  "kind": "workflow",
  "description": "Example workflow that downloads YouTube MP4, extracts audio, and transcribes it with Google Speech-to-Text.",
  "tags": [
    "youtube",
    "mp4",
    "ffmpeg",
    "speech-to-text",
    "example"
  ],
  "registry": "https://github.com/tacogips/riela-packages",
  "workflowDirectory": "workflows/youtube-mp4-to-text",
  "checksumAlgorithm": "md5",
  "checksum": "01dea2dce35c043c8760d39b2a10b06b",
