    "digest": "7a9f0496a19e149010d1029544772f4cfc79e9817479e3f13af8b95566da0f28",
    "signatures": []
  },
  "environmentVariables": [
    {
      "name": "GOOGLE_ACCESS_TOKEN",
      "description": "OAuth access token for Google Cloud Speech-to-Text and Cloud Storage. Provide one of GOOGLE_ACCESS_TOKEN, GOOGLE_APPLICATION_CREDENTIALS, or GOOGLE_APPLICATION_CREDENTIALS_JSON; gcloud is used as a fallback token source when none is set.",
      "required": false,
      "secret": true
    },
    {
      "name": "GOOGLE_APPLICATION_CREDENTIALS",
      "description": "Path to a Google service account credential JSON file able to upload to the target Cloud Storage bucket and run Speech-to-Text recognition. Alternative to GOOGLE_ACCESS_TOKEN and GOOGLE_APPLICATION_CREDENTIALS_JSON.",
      "required": false,
      "secret": false
    },
    {
      "name": "GOOGLE_APPLICATION_CREDENTIALS_JSON",
      "description": "Inline Google service account credential JSON. Alternative to GOOGLE_ACCESS_TOKEN and GOOGLE_APPLICATION_CREDENTIALS.",
      "required": false,
      "secret": true
    }
  ],
