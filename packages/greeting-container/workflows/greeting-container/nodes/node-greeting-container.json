{
  "id": "greeting-container",
  "description": "Run Node.js inside a container and output a greeting with the current datetime.",
  "nodeType": "container",
  "variables": {},
  "container": {
    "build": {
      "contextPath": "containers/greeting-node",
      "containerfilePath": "containers/greeting-node/Containerfile"
    },
    "entrypoint": ["node", "/app/greeting.js"],
    "argsTemplate": ["{{workflowInput.name}}"],
    "envTemplate": {
      "GREETING_INDEX": "{{workflowInput.greetingIndex}}",
      "GREETING_TIMEZONE": "{{workflowInput.timezone}}"
    },
    "workingDirectory": "/app",
    "workspace": {
      "mode": "ephemeral",
      "mountPath": "/workspace"
    },
    "resources": {
      "cpuMax": 1,
      "memoryMaxMb": 256,
      "pidsMax": 64
    },
    "networkPolicy": "disabled"
  },
  "output": {
    "description": "Return greeting text and datetime generated by Node.js in the container."
  }
}
