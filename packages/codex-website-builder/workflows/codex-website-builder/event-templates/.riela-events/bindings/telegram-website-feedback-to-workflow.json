{
  "id": "telegram-website-feedback-to-workflow",
  "enabled": false,
  "sourceId": "telegram-website-feedback",
  "outputDestinations": [
    "telegram-website-feedback-replies"
  ],
  "workflowName": "codex-website-builder",
  "match": {
    "eventType": "chat.message"
  },
  "inputMapping": {
    "mode": "template",
    "template": {
      "feedback": "{{event.input.text}}",
      "history": "{{event.input.history}}",
      "historySource": "{{event.input.historySource}}",
      "attachments": "{{event.input.attachments}}",
      "imagePaths": "{{event.input.imagePaths}}",
      "attachmentText": "{{event.input.attachmentText}}",
      "conversationId": "{{event.conversation.id}}",
      "threadId": "{{event.conversation.threadId}}",
      "sourceId": "{{event.sourceId}}",
      "actorId": "{{event.actor.id}}",
      "actorDisplayName": "{{event.actor.displayName}}",
      "eventId": "{{event.eventId}}"
    },
    "mirrorToHumanInput": true
  },
  "execution": {
    "async": true,
    "dedupeWindowMs": 86400000,
    "maxConcurrentPerKey": 1,
    "concurrencyKey": "{{event.sourceId}}:{{event.conversation.id}}"
  },
  "taskPlanning": {
    "enabled": false
  },
  "mailboxBridge": {
    "output": {
      "progress": {
        "mode": "none"
      }
    }
  }
}
